# =====================================================================
#  E-MAILS DES DEVIS/CONTACT (Resend) — modèle multi-clients
# =====================================================================
# Architecture pour dupliquer des sites par client :
#   - 1 SEUL domaine d'agence + 1 SEUL compte Resend (partagés)
#   - Une fois le domaine vérifié dans Resend, on peut envoyer VERS
#     n'importe quelle boîte mail (celle de chaque client).
#   - Par site, seul LEAD_TO change (la boîte du client).
#
# Sans RESEND_API_KEY, le formulaire fonctionne mais n'envoie pas
# d'e-mail (la demande est seulement loggée côté serveur).

# Clé API du compte Resend de l'agence (la MÊME pour tous les sites).
RESEND_API_KEY=

# Expéditeur. Peut être une simple adresse sur le domaine d'agence
# (ex. "leads@mon-agence.fr") : le nom de l'entreprise du site est
# ajouté automatiquement. Ou un "Nom <adresse>" complet.
RESEND_FROM=leads@mon-agence.fr

# Boîte mail qui REÇOIT les demandes — propre à CE client.
LEAD_TO=sanadclean30@gmail.com

# =====================================================================
#  PRISE DE RENDEZ-VOUS (Cal.com) — optionnel
# =====================================================================
# Lien Cal au format "utilisateur/type-d-evenement" (ex: sanadclean/menage).
# Sans cette variable, la page /rendez-vous affiche un repli (appel / WhatsApp).
NEXT_PUBLIC_CAL_LINK=
